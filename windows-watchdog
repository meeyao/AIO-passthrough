#!/usr/bin/env bash
# windows-watchdog: Monitors the VM and triggers host reset if VM crashes
# while holding the GPU.

set -euo pipefail

STATE_FILE="/etc/passthrough/passthrough.conf"
[[ -f "${STATE_FILE}" ]] || { echo "No state file found." >&2; exit 1; }
source "${STATE_FILE}"

VM_NAME="${VM_NAME:-windows}"
GPU_PCI="${GPU_PCI:-}"

virsh_timeout() {
  if command -v timeout >/dev/null 2>&1; then
    timeout 5s virsh -c qemu:///system "$@" 2>/dev/null
  else
    virsh -c qemu:///system "$@" 2>/dev/null
  fi
}

is_vm_running() {
  [[ "$(virsh_timeout domstate "${VM_NAME}" || true)" == "running" ]]
}

is_gpu_in_vfio() {
  [[ -n "${GPU_PCI}" ]] && lspci -nnk -s "${GPU_PCI}" | grep -q "vfio-pci"
}

gpu_driver_missing() {
  [[ -n "${GPU_PCI}" ]] && ! lspci -nnk -s "${GPU_PCI}" | grep -q "Kernel driver in use:"
}

echo "Starting windows-watchdog for ${VM_NAME}..."

while true; do
  vm_state="$(virsh_timeout domstate "${VM_NAME}" || true)"
  if [[ -z "${vm_state}" ]]; then
    if is_gpu_in_vfio || gpu_driver_missing; then
      echo "[$(date)] virsh domstate timed out or failed while the GPU is detached. Triggering reset-host..."
      /usr/local/bin/passthrough-reset-host
    fi
  elif [[ "${vm_state}" != "running" ]]; then
    if is_gpu_in_vfio || gpu_driver_missing; then
      echo "[$(date)] VM ${VM_NAME} state is '${vm_state}' while the GPU is detached. Triggering reset-host..."
      /usr/local/bin/passthrough-reset-host
    fi
  fi
  sleep 10
done
