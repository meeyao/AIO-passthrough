#!/usr/bin/env bash
set -euo pipefail

STATE_FILE="${STATE_FILE:-/etc/passthrough/passthrough.conf}"
if [[ -f "${STATE_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${STATE_FILE}"
fi

VM_NAME="${VM_NAME:-windows}"
URI="${LIBVIRT_URI:-qemu:///system}"
ACTION="${1:-go}"

run_helper() {
  local helper="$1"
  shift
  command -v "${helper}" >/dev/null 2>&1 || {
    echo "missing helper: ${helper}" >&2
    exit 1
  }
  exec "${helper}" "$@"
}

run_helper_wait() {
  local helper="$1"
  shift
  command -v "${helper}" >/dev/null 2>&1 || {
    echo "missing helper: ${helper}" >&2
    exit 1
  }
  "${helper}" "$@"
}

confirm() {
  local message="$1"
  local default="${2:-n}"
  local suffix='[y/N]'
  local answer
  [[ "${default}" == "y" ]] && suffix='[Y/n]'
  read -r -p "${message} ${suffix}: " answer
  answer="${answer:-$default}"
  [[ "${answer}" =~ ^[Yy]([Ee][Ss])?$ ]]
}

run_maybe_sudo_wait() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

gpu_drm_device_paths() {
  local sysfs_base="$1"
  local drm_dir entry devnode
  drm_dir="${sysfs_base}/drm"
  [[ -d "${drm_dir}" ]] || return 0

  for entry in "${drm_dir}"/card* "${drm_dir}"/renderD*; do
    [[ -e "${entry}" ]] || continue
    devnode="/dev/$(basename "${entry}")"
    [[ -e "${devnode}" ]] && printf '%s\n' "${devnode}"
  done
}

nvidia_device_minor_for_pci() {
  local info_file="$1"
  [[ -f "${info_file}" ]] || return 0
  awk -F': *' '/Device Minor/ {print $2; exit}' "${info_file}" 2>/dev/null || true
}

gpu_device_paths() {
  local sysfs_base info_file minor
  [[ -n "${GPU_PCI:-}" ]] || return 0
  sysfs_base="/sys/bus/pci/devices/${GPU_PCI}"
  [[ -d "${sysfs_base}" ]] || return 0

  gpu_drm_device_paths "${sysfs_base}"

  info_file="/proc/driver/nvidia/gpus/${GPU_PCI}/information"
  minor="$(nvidia_device_minor_for_pci "${info_file}")"
  if [[ "${minor}" =~ ^[0-9]+$ ]] && [[ -e "/dev/nvidia${minor}" ]]; then
    printf '%s\n' "/dev/nvidia${minor}"
  fi
}

gpu_consumer_pids_for_paths() {
  local -a devices=("$@")
  if command -v fuser >/dev/null 2>&1; then
    [[ "${#devices[@]}" -gt 0 ]] || return 0
    run_maybe_sudo_wait fuser "${devices[@]}" 2>/dev/null | grep -Eo '[0-9]+' | sort -u || true
  fi
}

gpu_consumer_cgroup() {
  local pid="$1"
  cat "/proc/${pid}/cgroup" 2>/dev/null || true
}

gpu_container_runtime() {
  local pid="$1"
  local cgroup
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  if [[ "${cgroup}" == *docker* ]]; then
    printf 'docker\n'
  elif [[ "${cgroup}" == *libpod* || "${cgroup}" == *podman* ]]; then
    printf 'podman\n'
  fi
}

gpu_container_id() {
  local pid="$1"
  local cgroup id
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  id="$(printf '%s\n' "${cgroup}" | grep -Eo '[0-9a-f]{64}|[0-9a-f]{32}' | tail -n1 || true)"
  [[ -n "${id}" ]] && printf '%s\n' "${id}"
}

gpu_container_ref() {
  local pid="$1"
  local runtime id
  runtime="$(gpu_container_runtime "${pid}")"
  id="$(gpu_container_id "${pid}")"
  [[ -n "${runtime}" && -n "${id}" ]] && printf '%s:%s\n' "${runtime}" "${id}"
}

container_display_name() {
  local runtime="$1"
  local id="$2"
  local name=""
  case "${runtime}" in
    docker)
      if command -v docker >/dev/null 2>&1; then
        name="$(run_maybe_sudo_wait docker inspect --format '{{.Name}}' "${id}" 2>/dev/null | sed 's#^/##' || true)"
      fi
      ;;
    podman)
      if command -v podman >/dev/null 2>&1; then
        name="$(run_maybe_sudo_wait podman inspect --format '{{.Name}}' "${id}" 2>/dev/null || true)"
      fi
      ;;
  esac
  [[ -n "${name}" ]] && printf '%s\n' "${name}" || printf '%s\n' "${id:0:12}"
}

gpu_consumer_origin() {
  local pid="$1"
  local cgroup runtime id name
  cgroup="$(gpu_consumer_cgroup "${pid}")"
  if [[ "${cgroup}" == *docker* ]]; then
    runtime="docker"
    id="$(gpu_container_id "${pid}")"
    name="$(container_display_name "${runtime}" "${id}")"
    printf 'docker container (%s)\n' "${name}"
  elif [[ "${cgroup}" == *containerd* ]]; then
    printf 'containerd container\n'
  elif [[ "${cgroup}" == *kubepods* ]]; then
    printf 'kubernetes pod\n'
  elif [[ "${cgroup}" == *libpod* || "${cgroup}" == *podman* ]]; then
    runtime="podman"
    id="$(gpu_container_id "${pid}")"
    name="$(container_display_name "${runtime}" "${id}")"
    printf 'podman container (%s)\n' "${name}"
  elif [[ "${cgroup}" == *user.slice* ]]; then
    printf 'user session\n'
  else
    printf 'host process\n'
  fi
}

list_gpu_containers() {
  local -a pids=("$@")
  local pid ref
  for pid in "${pids[@]}"; do
    ref="$(gpu_container_ref "${pid}")"
    [[ -n "${ref}" ]] && printf '%s\n' "${ref}"
  done | sort -u
}

print_gpu_containers() {
  local -a refs=("$@")
  local ref runtime id name
  for ref in "${refs[@]}"; do
    runtime="${ref%%:*}"
    id="${ref#*:}"
    name="$(container_display_name "${runtime}" "${id}")"
    printf '  - %s  %s  id=%s\n' "${runtime}" "${name}" "${id:0:12}"
  done
}

stop_container_ref() {
  local ref="$1"
  local runtime id
  runtime="${ref%%:*}"
  id="${ref#*:}"
  case "${runtime}" in
    docker)
      command -v docker >/dev/null 2>&1 || return 1
      run_maybe_sudo_wait docker stop -t 15 "${id}" >/dev/null
      ;;
    podman)
      command -v podman >/dev/null 2>&1 || return 1
      run_maybe_sudo_wait podman stop -t 15 "${id}" >/dev/null
      ;;
    *)
      return 1
      ;;
  esac
}

gracefully_stop_gpu_containers() {
  local -a refs=("$@")
  local ref failed=0
  for ref in "${refs[@]}"; do
    stop_container_ref "${ref}" || failed=1
  done
  return "${failed}"
}

print_gpu_consumers() {
  local -a pids=("$@")
  local pid user comm origin
  for pid in "${pids[@]}"; do
    [[ -d "/proc/${pid}" ]] || continue
    user="$(ps -o user= -p "${pid}" 2>/dev/null | awk '{print $1}' || true)"
    comm="$(ps -o comm= -p "${pid}" 2>/dev/null | sed 's/^[[:space:]]*//' || true)"
    origin="$(gpu_consumer_origin "${pid}")"
    printf '  - pid %s  user=%s  cmd=%s  origin=%s\n' \
      "${pid}" "${user:-unknown}" "${comm:-unknown}" "${origin}"
  done
}

kill_gpu_consumers() {
  local -a pids=("$@")
  [[ "${#pids[@]}" -gt 0 ]] || return 0
  run_maybe_sudo_wait kill -TERM "${pids[@]}" 2>/dev/null || true
  sleep 2
  run_maybe_sudo_wait kill -KILL "${pids[@]}" 2>/dev/null || true
}

preflight_gpu_release() {
  local -a devices=()
  local -a pids=()
  local -a containers=()
  local -a remaining=()

  mapfile -t devices < <(gpu_device_paths)
  [[ "${#devices[@]}" -gt 0 ]] || return 0

  mapfile -t pids < <(gpu_consumer_pids_for_paths "${devices[@]}")
  [[ "${#pids[@]}" -gt 0 ]] || return 0

  echo "GPU preflight: the selected passthrough GPU ${GPU_PCI:-} is still in use."
  echo "Resolved device nodes:"
  printf '  - %s\n' "${devices[@]}"
  echo
  echo "Processes still holding the selected GPU:"
  print_gpu_consumers "${pids[@]}"
  echo
  if [[ "${MODE:-single}" == "single" ]]; then
    echo "This host is in single-GPU mode, so the desktop or local apps may still be using the same GPU the VM needs."
  else
    echo "This host is in dedicated-GPU mode, so the passthrough GPU is unexpectedly busy."
  fi
  echo "The libvirt hook will try to evict GPU users, but some apps and containers cannot be shut down gracefully."

  mapfile -t containers < <(list_gpu_containers "${pids[@]}")
  if [[ "${#containers[@]}" -gt 0 ]]; then
    echo
    echo "Detected containers using the GPU:"
    print_gpu_containers "${containers[@]}"
    echo
    if confirm "Try to stop these containers gracefully before force-killing anything?" "y"; then
      gracefully_stop_gpu_containers "${containers[@]}" || true
      sleep 2
      mapfile -t pids < <(gpu_consumer_pids_for_paths "${devices[@]}")
      [[ "${#pids[@]}" -gt 0 ]] || return 0
      echo "GPU users still present after graceful container stop:"
      print_gpu_consumers "${pids[@]}"
      echo
    fi
  fi

  if ! confirm "Force-kill these GPU users before starting ${VM_NAME}?" "n"; then
    echo "Start cancelled."
    return 1
  fi

  kill_gpu_consumers "${pids[@]}"
  mapfile -t remaining < <(gpu_consumer_pids_for_paths "${devices[@]}")
  [[ "${#remaining[@]}" -gt 0 ]] || return 0

  echo "Some GPU users are still present after the force-kill attempt:"
  print_gpu_consumers "${remaining[@]}"
  echo
  echo "Starting ${VM_NAME} may still fail until those processes release the GPU."
  confirm "Continue and let the libvirt hook make the final attempt?" "n"
}

can_launch_viewer() {
  [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]
}

launch_spice_viewer() {
  can_launch_viewer || {
    echo "VM is running. Open it with virt-manager or virt-viewer." >&2
    return 0
  }

  if command -v virt-viewer >/dev/null 2>&1; then
    nohup virt-viewer --connect "${URI}" "${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in virt-viewer..."
    return 0
  fi

  if command -v remote-viewer >/dev/null 2>&1; then
    nohup remote-viewer "spice://localhost?title=${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in remote-viewer..."
    return 0
  fi

  if command -v virt-manager >/dev/null 2>&1; then
    nohup virt-manager --connect "${URI}" --show-domain-console "${VM_NAME}" >/dev/null 2>&1 &
    echo "Opening ${VM_NAME} in virt-manager..."
    return 0
  fi

  echo "VM is running. Open it with virt-manager or virt-viewer." >&2
}

vm_state() {
  virsh -c "${URI}" domstate "${VM_NAME}" 2>/dev/null || true
}

domain_exists() {
  virsh -c "${URI}" dominfo "${VM_NAME}" >/dev/null 2>&1
}

domain_xml() {
  local domain_name="${1:-${VM_NAME}}"
  virsh -c "${URI}" dumpxml "${domain_name}" 2>/dev/null || true
}

domain_exists_named() {
  local domain_name="${1:-${VM_NAME}}"
  virsh -c "${URI}" dominfo "${domain_name}" >/dev/null 2>&1
}

xml_has_gpu_hostdev() {
  local xml="$1"
  [[ -n "${GPU_PCI:-}" ]] || return 1
  printf '%s' "${xml}" | grep -Fq "domain='0x${GPU_PCI:0:4}' bus='0x${GPU_PCI:5:2}' slot='0x${GPU_PCI:8:2}' function='0x${GPU_PCI:11:1}'"
}

xml_has_spice_qxl() {
  local xml="$1"
  printf '%s' "${xml}" | grep -Eq "<graphics type='spice'|<video>|<channel type='spicevmc'|<redirdev "
}

infer_stage() {
  local xml install_name
  install_name="${VM_NAME}-spice"

  if domain_exists_named "${install_name}"; then
    printf 'spice-install\n'
    return 0
  fi

  if ! domain_exists; then
    printf 'host-configured\n'
    return 0
  fi

  xml="$(domain_xml "${VM_NAME}")"
  if xml_has_gpu_hostdev "${xml}"; then
    printf 'gpu-passthrough\n'
    return 0
  fi

  printf 'spice-install\n'
}

print_next_step() {
  case "$(infer_stage)" in
    host-configured)
      echo "Next step: run ./windows"
      echo "This will create the first boot Spice install VM."
      ;;
    spice-install)
      echo "Next step: run ./windows"
      echo "If the Spice VM is off, it will ask whether to resume install or finalize."
      ;;
    gpu-passthrough)
      echo "Next step: run ./windows"
      echo "This starts the finalized GPU passthrough VM."
      ;;
    *)
      echo "Next step: unknown"
      echo "The install stage in ${STATE_FILE} is not recognized."
      ;;
  esac
}

run_stage_action() {
  local state stage xml
  state="$(vm_state)"
  stage="$(infer_stage)"

  case "${stage}" in
    host-configured)
      run_helper_wait /usr/local/bin/passthrough-create-vm
      launch_spice_viewer
      exit 0
      ;;
    spice-install)
      case "${state}" in
        running)
          echo "${VM_NAME} is already running in the Spice install phase."
          launch_spice_viewer
          exit 0
          ;;
        shut\ off|shut\ off$|"")
          if confirm "Windows install VM is shut down. Resume the Spice install VM?" "y"; then
            virsh -c "${URI}" start "${VM_NAME}"
            launch_spice_viewer
            exit 0
          fi
          if confirm "Switch this VM to GPU passthrough now?" "n"; then
            if [[ "${EUID}" -eq 0 ]]; then
              /usr/local/bin/passthrough-attach-gpu
            else
              sudo /usr/local/bin/passthrough-attach-gpu
            fi
            preflight_gpu_release || exit 1
            exec virsh -c "${URI}" start "${VM_NAME}"
          fi
          echo "Leaving ${VM_NAME} shut down."
          exit 0
          ;;
        *)
          virsh -c "${URI}" start "${VM_NAME}"
          launch_spice_viewer
          exit 0
          ;;
      esac
      ;;
    gpu-passthrough)
      xml="$(domain_xml "${VM_NAME}")"
      if ! xml_has_gpu_hostdev "${xml}"; then
        echo "Refusing to start passthrough: ${VM_NAME} exists but does not have the configured GPU attached." >&2
        echo "Inspect with: ./windows xml" >&2
        exit 1
      fi
      if xml_has_spice_qxl "${xml}"; then
        echo "Detected stale mixed VM config for ${VM_NAME}; reconciling passthrough settings first."
        if [[ "${EUID}" -eq 0 ]]; then
          /usr/local/bin/passthrough-attach-gpu
        else
          sudo /usr/local/bin/passthrough-attach-gpu
        fi
        xml="$(domain_xml "${VM_NAME}")"
      fi
      if [[ "${state}" == "running" ]]; then
        echo "${VM_NAME} is already running"
        exit 0
      fi
      preflight_gpu_release || exit 1
      exec virsh -c "${URI}" start "${VM_NAME}"
      ;;
    *)
      echo "Unknown install stage: ${stage}" >&2
      exit 1
      ;;
  esac
}

case "${ACTION}" in
  go)
    run_stage_action
    ;;
  start)
    if [[ "$(infer_stage)" == "host-configured" ]]; then
      run_stage_action
    fi
    ;;
  create|install)
    shift
    run_helper_wait /usr/local/bin/passthrough-create-vm "$@"
    launch_spice_viewer
    exit 0
    ;;
  autounattend)
    shift
    run_helper /usr/local/bin/passthrough-build-autounattend "$@"
    ;;
  attach-gpu)
    shift
    if [[ "${EUID}" -eq 0 ]]; then
      run_helper /usr/local/bin/passthrough-attach-gpu "$@"
    else
      exec sudo /usr/local/bin/passthrough-attach-gpu "$@"
    fi
    ;;
  finalize)
    shift
    if [[ "${EUID}" -eq 0 ]]; then
      run_helper /usr/local/bin/passthrough-attach-gpu "$@"
    else
      exec sudo /usr/local/bin/passthrough-attach-gpu "$@"
    fi
    ;;
  stop|shutdown)
    exec virsh -c "${URI}" shutdown "${VM_NAME}"
    ;;
  destroy)
    exec virsh -c "${URI}" destroy "${VM_NAME}"
    ;;
  reset)
    exec virsh -c "${URI}" reset "${VM_NAME}"
    ;;
  reboot)
    exec virsh -c "${URI}" reboot "${VM_NAME}"
    ;;
  status)
    echo "install_stage=$(infer_stage)"
    print_next_step
    echo
    exec virsh -c "${URI}" domstate "${VM_NAME}"
    ;;
  reset-host)
    shift
    run_helper /usr/local/bin/passthrough-reset-host "$@"
    ;;
  dump-vbios)
    shift
    run_helper /usr/local/bin/passthrough-dump-vbios "$@"
    ;;
  next)
    print_next_step
    exit 0
    ;;
  xml)
    exec virsh -c "${URI}" dumpxml "${VM_NAME}"
    ;;
  *)
    echo "usage: windows [start|create|install|autounattend|attach-gpu|finalize|dump-vbios|reset-host|stop|shutdown|destroy|reset|reboot|status|next|xml]" >&2
    echo "Run ./windows with no arguments for the stage-aware one-command flow." >&2
    exit 2
    ;;
esac

state="$(virsh -c "${URI}" domstate "${VM_NAME}" 2>/dev/null || true)"

if [[ "${state}" == "running" ]]; then
  echo "${VM_NAME} is already running"
  exit 0
fi

if [[ "$(infer_stage)" == "gpu-passthrough" ]]; then
  preflight_gpu_release || exit 1
fi

exec virsh -c "${URI}" start "${VM_NAME}"
